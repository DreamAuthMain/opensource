{
  "name": "@dreamauth/base64url",
  "description": "DreamAuth Base64URL",
  "version": "0.1.0",
  "author": "Chris Ackerman <chris@topher.land>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DreamAuthMain/opensource.git"
  },
  "files": [
    "lib/cjs/**",
    "lib/esm/**"
  ],
  "directories": {
    "lib": "lib"
  },
  "type": "module",
  "types": "lib/esm/exports.d.ts",
  "module": "lib/esm/exports.js",
  "main": "lib/cjs/exports.js",
  "exports": {
    ".": {
      "types": "./lib/esm/exports.d.ts",
      "import": "./lib/esm/exports.js",
      "default": "./lib/cjs/exports.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf lib out && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && echo '{ \"type\": \"commonjs\" }' > lib/cjs/package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "werk": {
    "tsc": {
      "config": [
        {
          "compilerOptions": {
            "noEmit": false,
            "rootDir": "src",
            "outDir": "lib/cjs",
            "module": "CommonJS"
          },
          "include": [
            "src"
          ],
          "exclude": [
            "**/*.test.*"
          ]
        },
        {
          "compilerOptions": {
            "noEmit": false,
            "rootDir": "src",
            "outDir": "lib/esm",
            "module": "NodeNext"
          },
          "include": [
            "src"
          ],
          "exclude": [
            "**/*.test.*"
          ]
        }
      ]
    }
  }
}
